(defn trivial-vertex []: @{builtin position} vec4f
  (vec4f (match (vertex-index)
           0 (vec2f -1.)
           1 (vec2f -1. 3.)
           _ (vec2f 3. -1.))
         0.
         1.))

(defn my-fragment [@{builtin position} pos: vec4f]: @{location 0} vec4f
  (vec4f 1.))

@cpu
(defn main []
  (spawn-window (fn []
                    (dispatch-render-shaders trivial-vertex my-fragment 3))))
