(def particle-count: u32
     10)

(var frame-index: u32)

@{address uniform
  group 0
  binding 0}
(var screenspace-scale: vec2f)

@{address uniform
  group 0
  binding 1}
(var solid-color: vec3f)

@{address uniform
  group 0
  binding 2}
(var line-pos: vec2f)

@{address uniform
  group 0
  binding 3}
(var line-offset: vec2f)

@{address uniform
  group 0
  binding 4}
(var line-width: f32)

@{address storage-write
  group 0
  binding 5}
(var particles: [vec4f])

(defn bi->uni [x: f32]: f32
  (-> x (+ 1.) (* 0.5)))

(defn vert-index-square-pos [i: u32]: vec2f
  (vec2f (if (or (== i 0) (== i 1) (== i 3))
           -1.
           1.)
         (if (or (== i 0) (== i 3) (== i 4))
           -1.
           1.)))

@compute
@{workgroup-size 1}
(defn randomize-particles [@{builtin global-invocation-id}
                           id: vec3u]
  (= (particles id.x)
     (vec4f 1.)
     #_(-> id.x
           f32
           (/ (f32 particle-count))
           (vec4f (vec3f 0.)))))

@vertex
(defn line-vertex [@{builtin vertex-index}
                   vertex-index: u32]: @{builtin position} vec4f
  (let [square-pos (vert-index-square-pos vertex-index)
        perp (-> line-offset
                 (vec2f (- (.y <>)) (.x <>))
                 normalize)]
    (vec4f (* screenspace-scale
              (+ line-pos
                 (* (* line-width square-pos.x)
                    perp)
                 (* (bi->uni square-pos.y)
                    line-offset)))
           0.
           1.)))

(struct DotVertOutput
  @{builtin position} pos: vec4f
  square-pos: vec2f)

@vertex
(defn particle-dots-vertex [@{builtin vertex-index}
                            vertex-index: u32]: DotVertOutput
  (let [square-pos (vert-index-square-pos (% vertex-index 6))
        particle (particles (/ vertex-index 6))]
    (DotVertOutput (vec4f (* screenspace-scale
                             (+ particle.xy
                                (* line-width square-pos)))
                          0.
                          1.)
                   square-pos)))

@fragment
(defn dot-frag [in: DotVertOutput]: @{location 0} vec4f
  (when (> (length in.square-pos) 1.)
    (discard))
  (vec4f solid-color 1.))

@fragment
(defn solid-color-frag [@{builtin position} pos: vec4f]: @{location 0} vec4f
  (vec4f solid-color 1.))

(defn draw-line [a: vec2f
                 b: vec2f
                 width: f32
                 color: vec3f]
  (= line-pos a)
  (= line-offset (- b a))
  (= solid-color color)
  (= line-width width)
  (dispatch-render-shaders line-vertex
                           solid-color-frag
                           6))

(defn draw-particles [radius: f32
                      color: vec3f]
  (= solid-color color)
  (= line-width radius)
  (dispatch-render-shaders particle-dots-vertex
                           dot-frag
                           (* 6 particle-count)))

@cpu
(defn main []
  (= particles
     (zeroed-array particle-count))
  (dispatch-compute-shader randomize-particles
                           (vec3u particle-count 0u 0u))
  (print particles)
  #_(spawn-window (fn []
                      (let [resolution (window-resolution)]
                        (= screenspace-scale
                           (/ (f32 (min resolution.x resolution.y))
                              (vec2f resolution))))
                      (draw-line (vec2f 0.)
                                 (-> frame-index
                                     f32
                                     (* 0.01)
                                     (vec2f (cos <>) (sin <>)))
                                 0.003
                                 (vec3f 1. 0. 1.))
                      (draw-particles 0.1 (vec3f 1.))
                      (+= frame-index 1))))
