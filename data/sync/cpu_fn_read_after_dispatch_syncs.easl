(defn get-elem [i: u32]: f32
  (data i))

@[storage-write 0 0]
(var data: [f32])

@cpu
(defn main []: ()
  (= data (zeroed-array 4u))
  (dispatch-compute-shader
   (fn []
       (let [id (global-invocation-id)]
         (when (< id.x (array-length data))
           (= (data id.x) (f32 id.x)))))
   (vec3u 4u 1u 1u))
  (print (get-elem 3u)))
