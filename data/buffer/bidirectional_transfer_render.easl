@{address storage-write
  group 0
  binding 0}
(var x: u32)

@vertex
(defn vert [@{builtin vertex-index} i: u32]: vec4f
  (if (== i 0u) (vec4f -1. -1. 0. 1.)
    (if (== i 1u) (vec4f 3. -1. 0. 1.)
                  (vec4f -1. 3. 0. 1.))))

@fragment
(defn square-x []: vec4f
  (= x (* x x))
  (vec4f 0.))

@cpu
(defn main []
  (spawn-window (fn []
                    (= x 5)
                    (print x)
                    (dispatch-render-shaders vert square-x 3)
                    (print x)
                    (close-window))))
